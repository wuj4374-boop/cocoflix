# ============ 应用配置 ============
NODE_ENV=development
APP_PORT=4000
APP_URL=http://localhost:3000
API_PREFIX=api/v1

# ============ 数据库配置 ============
DB_PATH=./data/cocoflix.db

# ============ JWT配置 ============
JWT_SECRET=cocoflix_jwt_secret_change_me_in_production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# ============ CORS配置 ============
CORS_ORIGIN=http://localhost:3000

# ============ 日志配置 ============
LOG_LEVEL=debug
LOG_DIR=logs

# ============ Swagger配置 ============
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ============ TMDB配置 ============
TMDB_API_KEY=your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_LANGUAGE=zh-CN
TMDB_FALLBACK_LANGUAGE=en-US
TMDB_IMAGE_PROXY_ENABLED=true
TMDB_IMAGE_CACHE_DIR=./storage/tmdb-images
TMDB_CACHE_TTL=86400
TMDB_REQUEST_TIMEOUT=10000
TMDB_MAX_CONCURRENT=5
TMDB_SCRAPE_CRON=0 3 * * *
TMDB_UPDATE_CRON=0 4 * * *

# ============ 存储配置 ============
STORAGE_PATH=./storage
MEDIA_PATH=./storage/media

# ============ 前端配置 ============
# API 基础地址（Next.js 会通过 rewrites 代理到此后端地址）
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# HLS 流媒体地址（本地 DB 模式下的 m3u8 基础路径，默认使用 API 代理）
# NEXT_PUBLIC_STREAM_URL=/api/v1/stream
